# Copy to .env for local overrides (optional; sensible dev defaults exist).
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.vercel.app
# Comma-separated origins allowed to call the API (the deployed frontend URL).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Or allow all origins (simplest for a public demo):
CORS_ALLOW_ALL_ORIGINS=False
